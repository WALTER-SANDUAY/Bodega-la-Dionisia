rules_version = '2';

// Reglas de Firestore para Finca la Dionisia.
// Cualquiera puede LEER (galería, videos, novedades se muestran en el sitio público).
// Solo un usuario autenticado (el administrador) puede ESCRIBIR (crear/borrar).

service cloud.firestore {
  match /databases/{database}/documents {

    match /galeria/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /videos/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /novedades/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /vinos/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}